---
import { Font } from 'astro:assets';
import IndexLayout from '../layout/IndexLayout.astro';

import '@welcome-home/wh-base/wh-base.css';
---

<style is:global>
@layer user-config {
  :root,
  :host {
    --font-family-title: var(--font-pilcrow-rounded);
    --font-family-base: var(--font-pilcrow-rounded);
    --font-family-code: var(--font-jetbrains-mono);
    --font-family-heading: var(--font-archivo);
    --font-weight-title: 800;
  }

  @media (prefers-color-scheme: dark) {
    :root,
    :host {
      --color-primary: hsl(343deg, 81%, 75%);
    }
  }

  @media (prefers-color-scheme: light) {
    :root,
    :host {
      --color-primary: hsl(347deg, 87%, 44%);
    }
  }
}
</style>

<IndexLayout>
  <Font cssVariable="--font-pilcrow-rounded" preload slot="fonts" />
  <Font cssVariable="--font-archivo" preload slot="fonts" />
  <Font cssVariable="--font-jetbrains-mono" slot="fonts" />
  <slot />
</IndexLayout>
